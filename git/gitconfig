[merge]
    tool = phpstorm

[merge "composer_json"]
    name = composer JSON file merge driver
    driver = ~/.composer/vendor/bin/composer-git-merge-driver %O %A %B %L %P
    recursive = binary

[core]
    excludesFile = ~/.gitignore
    editor = vim

[gpg]
    program = gpg
	format = ssh

[diff]
    tool = phpstorm
    colorMoved = default

[difftool]
    prompt = false

[difftool "phpstorm"]
    cmd = phpstorm diff $LOCAL $REMOTE 

[mergetool "phpstorm"]
    cmd = phpstorm merge $LOCAL $REMOTE $BASE $MERGED
    trustExitCode = true

[init]
    defaultBranch = main

[rebase]
    autoStash = true
    missingCommitsCheck = warn
    stat = yes

[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta
    blame = delta

[interactive]
    diffFilter = delta --color-only --features=interactive

[delta]
    line-numbers = true
    side-by-side = true
    hyperlinks = true
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true

[alias]
    mr = !sh -c 'git fetch $1 merge-requests/$2/head:mr-$1-$2 && git checkout mr-$1-$2' -

[remote "origin"]
    fetch = +refs/merge-requests/*:refs/remotes/origin/merge-requests/*

[rerere]
	enabled = true
